<Window x:Class="Thetacat.BackupRestore.Restore.ChooseRemapSourceTarget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Thetacat.BackupRestore.Restore"
        mc:Ignorable="d"
        Title="ChooseRemapSourceTarget" Height="620" Width="800">
    <StackPanel Orientation="Vertical">
        <GroupBox>
            <GroupBox.Header>
                <TextBlock Text="Source Information" />
            </GroupBox.Header>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Profile" />
                <ComboBox ItemsSource="{Binding Path=Profiles}"
                          SelectedItem="{Binding Path=SourceProfile}" />
                <TextBlock Text="SQL Connection" />
                <TextBox IsReadOnly="True" Text="{Binding Path=SourceSqlConnection}" />
                <TextBlock Text="Azure Storage" />
                <TextBox Text="{Binding Path=SourceAzureStorage}" />
                <TextBlock Text="Azure Container" />
                <TextBox Text="{Binding Path=SourceAzureContainer}" />
                <TextBlock Text="Catalog ID" />
                <TextBox IsReadOnly="True" Text="{Binding Path=SourceCatalogID}" />
                <TextBlock Text="Source Workgroup ID" />
                <TextBox IsReadOnly="True" Text="{Binding Path=SourceWorkgroupId}" />
            </StackPanel>
        </GroupBox>
        <GroupBox>
            <GroupBox.Header>
                <TextBlock Text="Target Information" />
            </GroupBox.Header>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{Binding Path=TargetProfile}" />
                <TextBlock Text="SQL Connection" />
                <TextBox IsReadOnly="True" Text="{Binding Path=TargetSqlConnection}" />
                <TextBlock Text="Azure Storage" />
                <TextBox Text="{Binding Path=TargetAzureStorage}" />
                <TextBlock Text="Azure Container" />
                <TextBox Text="{Binding Path=TargetAzureContainer}" />
                <TextBlock Text="Catalog ID" />
                <TextBox IsReadOnly="True" Text="{Binding Path=TargetCatalogID}" />
                <TextBlock Text="Target Workgroup ID" />
                <TextBox IsReadOnly="True" Text="{Binding Path=TargetWorkgroupId}" />
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Restore Options">
            <StackPanel Orientation="Vertical">
                <CheckBox Content="Migrate Azure Blobs" IsChecked="{Binding Path=MigrateAzureBlobs}" />
                <CheckBox Content="Migrate Workgroup" IsChecked="{Binding Path=MigrateWorkgroup}" />
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Guid Map">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Read ID mapping" />
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding Path=GuidMapExportPath}" Width="212" />
                    <Button Content="..." Click="BrowseForPath" />
                </StackPanel>
            </StackPanel>
        </GroupBox>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="DoCancel" />
            <Button Content="Remap" Click="DoOkClick" />
        </StackPanel>
    </StackPanel>
</Window>