<Window x:Class="Thetacat.UI.Options.CreateWorkgroup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Thetacat.UI.Options"
        mc:Ignorable="d"
        Title="CreateWorkgroup" Height="200" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <local:WorkgroupCache Grid.Row="0"/>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="64" Click="DoCancel" />
            <Button Content="OK" Width="64" Click="DoSaveWorkgroup" />
        </StackPanel>
    </Grid>
</Window>
